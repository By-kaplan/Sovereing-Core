<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NEFER-OS | 1.0.0-OMEGA | 09. HÜCRE (ROW HAMMER)</title>
    <style>
        :root {
            --bg-deep: #020617;
            --panel-bg: #0f172a;
            --text-neon: #38bdf8;
            --text-dim: #64748b;
            --hazard: #ef4444;
            --safety: #10b981;
            --warning: #f59e0b;
            --optic: #fbbf24; 
            --entropy: #8b5cf6; 
            --signal: #22d3ee; 
            --biometric: #10b981; 
            --shadow: #f43f5e;
            --resonance: #f97316;
            --thrashing: #ec4899;
            --hammer: #ef4444; /* 09. Hücre Rengi: Darbe Kırmızısı */
            --border: #1e293b;
            --cell-gap: 4px;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; cursor: crosshair; }

        body {
            font-family: "Courier New", Courier, monospace;
            background-color: var(--bg-deep);
            color: var(--text-neon);
            padding: 15px;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            gap: 15px;
            overflow: hidden;
        }

        .nefer-header {
            border: 1px solid var(--border);
            background: rgba(15, 23, 42, 0.9);
            padding: 15px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-left: 4px solid var(--hammer);
        }

        .nefer-header h1 { font-size: 1.2rem; color: var(--hammer); letter-spacing: 3px; font-weight: 800; }
        .meta-info { font-size: 0.7rem; color: var(--text-dim); text-align: right; }

        .cell-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(14px, 14px));
            gap: var(--cell-gap);
            background: var(--panel-bg);
            padding: 12px;
            border: 1px solid var(--border);
            justify-content: center;
        }

        .cell {
            width: 14px;
            height: 14px;
            background: #1e293b;
            border-radius: 1px;
            transition: all 0.3s ease;
        }

        .cell.active { background: var(--safety); box-shadow: 0 0 8px var(--safety); }
        .cell.optic-active { background: var(--optic); box-shadow: 0 0 12px var(--optic); }
        .cell.entropy-active { background: var(--entropy); box-shadow: 0 0 12px var(--entropy); }
        .cell.signal-active { background: var(--signal); box-shadow: 0 0 12px var(--signal); }
        .cell.biometric-active { background: var(--biometric); box-shadow: 0 0 12px var(--biometric); }
        .cell.shadow-active { background: var(--shadow); box-shadow: 0 0 12px var(--shadow); }
        .cell.resonance-active { background: var(--resonance); box-shadow: 0 0 12px var(--resonance); }
        .cell.thrashing-active { background: var(--thrashing); box-shadow: 0 0 12px var(--thrashing); }
        .cell.hammer-active { background: var(--hammer); box-shadow: 0 0 12px var(--hammer); }
        .cell.loading { background: var(--warning); animation: pulse 1s infinite; }

        @keyframes pulse { 0% { opacity: 0.4; } 50% { opacity: 1; } 100% { opacity: 0.4; } }

        .console-container {
            flex: 1;
            display: grid;
            grid-template-columns: 1fr 340px;
            gap: 15px;
            overflow: hidden;
        }

        .main-display {
            display: flex;
            flex-direction: column;
            gap: 15px;
            overflow: hidden;
        }

        .viz-view {
            height: 220px;
            background: #000;
            border: 1px solid var(--border);
            position: relative;
            overflow: hidden;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
            gap: 2px;
        }

        canvas { width: 100%; height: 100%; image-rendering: pixelated; border-right: 1px solid var(--border); }
        .viz-box { position: relative; overflow: hidden; background: #020617; border-right: 1px solid var(--border); }
        .viz-box:last-child { border-right: none; }

        .log-panel {
            flex: 1;
            background: var(--panel-bg);
            border: 1px solid var(--border);
            padding: 15px;
            overflow-y: auto;
            font-size: 0.75rem;
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .log-entry { border-left: 2px solid transparent; padding-left: 8px; }
        .log-entry.sys { border-left-color: var(--warning); color: var(--warning); }
        .log-entry.hammer { border-left-color: var(--hammer); color: var(--hammer); }

        .tools-panel {
            background: var(--panel-bg);
            border: 1px solid var(--border);
            padding: 20px;
            display: flex;
            flex-direction: column;
            gap: 6px;
            overflow-y: auto;
        }

        .btn {
            background: #1e293b;
            border: 1px solid var(--border);
            color: var(--text-neon);
            padding: 6px 10px;
            font-size: 0.55rem;
            font-weight: bold;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .btn.active-op-hammer { border-color: var(--hammer); background: #450a0a; color: white; }

        .protocol-footer {
            background: #020617;
            padding: 20px;
            border: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .attribution { font-size: 0.7rem; color: var(--text-dim); }
        .flag-box { opacity: 0.7; }

        .hammer-hud {
            position: absolute;
            bottom: 5px;
            left: 5px;
            font-size: 0.45rem;
            color: var(--hammer);
            font-weight: bold;
        }
    </style>
</head>
<body>

    <header class="nefer-header">
        <div>
            <h1>NEFER-OS // ROW_HAMMER_SIM</h1>
            <div style="font-size: 0.6rem; color: var(--text-dim);">09. HÜCRE: BELLEK HÜCRESİ DARBELEME VE VERİ BOZMA</div>
        </div>
        <div class="meta-info">
            <div id="clock">00:00:00</div>
            <div>ARCHITECT: ÖMER KAPLAN</div>
        </div>
    </header>

    <div class="cell-grid" id="cell-grid"></div>

    <div class="console-container">
        <div class="main-display">
            <div class="viz-view">
                <div class="viz-box" id="resonance-viz"><canvas id="resonance-canvas"></canvas></div>
                <div class="viz-box" id="thrashing-viz"><canvas id="thrashing-canvas"></canvas></div>
                <div class="viz-box" id="hammer-viz">
                    <div style="position:absolute; top:5px; left:10px; font-size:0.4rem; color:var(--hammer); background:rgba(0,0,0,0.8); z-index:5;">MEMORY_BIT_FLIP_ACTIVE</div>
                    <canvas id="hammer-canvas"></canvas>
                    <div id="hammer-hud" class="hammer-hud">ACCESS_RATE: 0 MHz | STATUS: STABLE</div>
                </div>
            </div>
            <div class="log-panel" id="sys-log"></div>
        </div>

        <aside class="tools-panel">
            <button class="btn" onclick="OpticEngine.toggle()"><span>02: OPTIC</span></button>
            <button class="btn" onclick="ResonanceEngine.toggle()"><span>07: RESONANCE</span></button>
            <button class="btn" onclick="ThrashingEngine.toggle()"><span>08: I/O THRASHING</span></button>
            <button class="btn" id="hammer-toggle" onclick="HammerEngine.toggle()">
                <span>09: ROW HAMMER</span>
                <span id="hammer-status">KAPALI</span>
            </button>
            <button class="btn" onclick="Kernel.sequenceBoot()" style="margin-top: 10px;">
                <span>SIRALI ÖNYÜKLEME (BOOT)</span>
                <span>▶</span>
            </button>
            
            <div style="margin-top: auto; font-size: 0.55rem; color: var(--text-dim); border-top: 1px solid var(--border); padding-top: 10px;">
                HÜCRE 09: Ultra yüksek hızlı bellek erişimi ile bit-flipping simülasyonu uygular.
            </div>
        </aside>
    </div>

    <footer class="protocol-footer">
        <div class="attribution">
            <p><b>09. HÜCRE: MEMORY ROW-HAMMER SIMULATION</b> - Bellek Donanımı Sabotajı</p>
            <p>Architect: Ömer Kaplan | Organization: Kaplan Precision Dept.</p>
        </div>
        <div class="flag-box">
            <svg width="100" height="60" viewBox="0 0 150 100">
                <defs><mask id="m"><rect width="150" height="100" fill="white"/><circle cx="61.25" cy="50" r="20" fill="black"/></mask></defs>
                <circle cx="50" cy="50" r="25" fill="#ef4444" mask="url(#m)"/><path d="M95,50 L86.18,52.86 L88.54,43.82 L81.18,37.14 L90.41,36.55 L95,28 L99.59,36.55 L108.82,37.14 L101.46,43.82 L103.82,52.86 Z" fill="#ef4444" transform="rotate(-18, 95, 40) translate(0, 5)"/></svg>
        </div>
    </footer>

    <script>
        const Kernel = {
            startTime: Date.now(),
            init() {
                this.setupGrid();
                this.updateCell(1, "active");
                setInterval(() => { document.getElementById('clock').textContent = new Date().toLocaleTimeString(); }, 1000);
                this.log("Kernel aktif. Hücre 09 operasyonel.", "sys");
            },
            setupGrid() {
                const grid = document.getElementById('cell-grid');
                for(let i=1; i<=92; i++) {
                    const d = document.createElement('div');
                    d.className = 'cell'; d.id = `cell-${i}`;
                    grid.appendChild(d);
                }
            },
            updateCell(id, status) {
                const el = document.getElementById(`cell-${id}`);
                if(el) el.className = `cell ${status}`;
            },
            log(msg, type = "sys") {
                const l = document.getElementById('sys-log');
                const e = document.createElement('div');
                e.className = `log-entry ${type}`;
                e.textContent = `[${new Date().toLocaleTimeString()}] ${msg}`;
                l.appendChild(e);
                l.scrollTop = l.scrollHeight;
            },
            async sequenceBoot() {
                for(let i=2; i<=92; i++) {
                    if([2,7,8,9].includes(i)) continue;
                    this.updateCell(i, "loading");
                    await new Promise(r => setTimeout(r, 10));
                    this.updateCell(i, "active");
                }
            }
        };

        // Engine Mocks
        const OpticEngine = { active: false, toggle() { this.active = !this.active; Kernel.updateCell(2, this.active ? "optic-active" : "active"); } };
        const ResonanceEngine = { active: false, toggle() { this.active = !this.active; Kernel.updateCell(7, this.active ? "resonance-active" : "active"); } };
        const ThrashingEngine = { active: false, toggle() { this.active = !this.active; Kernel.updateCell(8, this.active ? "thrashing-active" : "active"); } };

        const HammerEngine = {
            active: false,
            buffer: null,
            view: null,
            loop: null,
            accessCount: 0,
            toggle() {
                this.active = !this.active;
                const btn = document.getElementById('hammer-toggle');
                const canvas = document.getElementById('hammer-canvas');
                const hud = document.getElementById('hammer-hud');
                const ctx = canvas.getContext('2d');
                
                if(this.active) {
                    btn.classList.add('active-op-hammer');
                    document.getElementById('hammer-status').textContent = "AKTİF";
                    Kernel.updateCell(9, "hammer-active");
                    Kernel.log("ROW-HAMMER SİMÜLASYONU BAŞLATILDI: BELLEK HÜCRELERİ DARBELENİYOR.", "hammer");
                    this.start(canvas, ctx, hud);
                } else {
                    btn.classList.remove('active-op-hammer');
                    document.getElementById('hammer-status').textContent = "KAPALI";
                    Kernel.updateCell(9, "active");
                    this.stop(ctx, canvas);
                }
            },
            start(c, ctx, hud) {
                // Bellek alanı tahsisi (Simüle)
                this.buffer = new ArrayBuffer(1024 * 1024 * 4); // 4MB
                this.view = new Uint32Array(this.buffer);

                const draw = () => {
                    if(!this.active) return;
                    
                    // Hammering işlemi simülasyonu
                    for(let i=0; i<10000; i++) {
                        const addr1 = (i * 128) % this.view.length;
                        const addr2 = (addr1 + 256) % this.view.length;
                        const v = this.view[addr1] + this.view[addr2]; // Sahte erişim
                        this.accessCount++;
                    }

                    // Görselleştirme
                    ctx.fillStyle = "rgba(2, 6, 23, 0.4)";
                    ctx.fillRect(0, 0, c.width, c.height);
                    
                    for(let k=0; k<15; k++) {
                        const x = Math.random() * c.width;
                        const y = Math.random() * c.height;
                        if(Math.random() > 0.95) {
                            ctx.fillStyle = "var(--hammer)";
                            ctx.fillRect(x, y, 3, 3);
                            if(k === 0) Kernel.log(`Bit-Flip: 0x${(Math.random()*0xFFFF).toString(16)} hücresinde veri bozulması.`, "hammer");
                        } else {
                            ctx.fillStyle = "#1e293b";
                            ctx.fillRect(x, y, 2, 2);
                        }
                    }

                    hud.textContent = `ACCESS_RATE: ${Math.floor(this.accessCount / 1000)} MHz | STATUS: HAMMERING`;
                    this.accessCount = 0;
                    this.loop = requestAnimationFrame(draw);
                };
                draw();
            },
            stop(ctx, c) {
                this.active = false;
                this.buffer = null;
                this.view = null;
                cancelAnimationFrame(this.loop);
                ctx.clearRect(0,0,c.width, c.height);
                document.getElementById('hammer-hud').textContent = "ACCESS_RATE: 0 MHz | STATUS: STABLE";
            }
        };

        window.onload = () => {
            Kernel.init();
            ["hammer", "resonance", "thrashing"].forEach(id => {
                const c = document.getElementById(id + "-canvas");
                if(c) { c.width = c.offsetWidth; c.height = c.offsetHeight; }
            });
        };
    </script>
</body>
</html>
